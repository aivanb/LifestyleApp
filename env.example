# =============================================================================
# TrackingApp — environment template (local + Docker)
# Copy to `.env` and fill in values. Never commit `.env`.
# Canonical template: `.env.example` (identical content; kept for README compatibility).
# =============================================================================

# --- MySQL (required) -------------------------------------------------------
# Docker: MYSQL_USER / MYSQL_PASSWORD must match DB_USER / DB_PASSWORD.
# The database named DB_NAME is created automatically in the MySQL container.
DB_NAME=tracking_app
DB_USER=tracking
DB_PASSWORD=change-me-app-user
DB_HOST=localhost
DB_PORT=3306

# Root password for the MySQL container (Docker only; not used by Django).
MYSQL_ROOT_PASSWORD=change-me-root

# --- Django (required) ------------------------------------------------------
SECRET_KEY=generate-a-long-random-string
DEBUG=True
# Comma-separated. Include your public hostname in production.
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: comma-separated origins for CSRF (e.g. https://app.example.com)
# CSRF_TRUSTED_ORIGINS=https://app.example.com

# --- CORS -------------------------------------------------------------------
# Comma-separated browser origins allowed to call the API.
# Leave unset for sensible localhost defaults (incl. Docker dev on :3000).
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- JWT --------------------------------------------------------------------
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_LIFETIME=3600
JWT_REFRESH_TOKEN_LIFETIME=604800

# --- OpenAI (optional) ------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# --- Frontend (CRA) ---------------------------------------------------------
# Dev without Docker: use full URL to Django. Docker dev/prod SPA: use /api (same origin).
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_ENV=development

# Dev server → Django proxy when using Docker Compose dev (set automatically in compose).
# DOCKER_API_PROXY=http://backend:8000

# --- Docker Compose publish ports (optional) --------------------------------
# BACKEND_PUBLISH_PORT=8000
# FRONTEND_PUBLISH_PORT=3000
# WEB_PUBLISH_PORT=80

# --- Docker production only -------------------------------------------------
# Set to 1 once to load reference data (invite keys, etc.) after migrations.
# RUN_SETUP_REQUIRED=0
